{
    "name": "RawAudioVAE_PQMF",
    "n_gpu": 1,

    "arch": {
        "type": "RawAudioVAE",
        "args": {
            "latent_dim": 32,
            "n_bands": 16,
            "channels": [64, 128, 256, 512],
            "strides": [4, 4, 2]
        }
    },

    "data_loader": {
        "type": "RawAudioDataLoader",
        "args": {
            "data_dir": ["dataset/medley-solos/organized_reeds"],
            "sr": 22050,
            "chunk_size": 16384,
            "batch_size": 128,
            "shuffle": true,
            "validation_split": 0.1,
            "num_workers": 4,
            "subset": "train"
        }
    },

    "optimizer": {
        "type": "Adam",
        "args": {
            "lr": 0.0003,
            "weight_decay": 0,
            "amsgrad": true
        }
    },

    "loss": "raw_audio_vae_loss",
    "metrics": [],

    "lr_scheduler": {
        "type": "StepLR",
        "args": {
            "step_size": 200,
            "gamma": 0.5
        }
    },

    "trainer": {
        "type": "RawAudioVaeAdversarialTrainer",
        "epochs": 1500,

        "save_dir": "saved/",
        "save_period": 10,
        "verbosity": 2,

        "monitor": "min val_loss",
        "early_stop": 1500,

        "tensorboardX": true,

        "beta_max": 0.01,
        "beta_warmup": 300,
        "free_bits": 0.5,

        "adv_start_epoch": 500,
        "lambda_adv": 0.5,
        "lambda_fm": 2.0,
        "discriminator": "waveform",
        "freeze_encoder": false
    }
}
