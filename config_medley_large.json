{
    "name": "SpecVAE_Medley_Large",
    "n_gpu": 1,

    "arch": {
        "type": "SpecVAE",
        "args": {
            "input_size": [64, 15],
            "latent_dim": 64,
            "is_featExtract": false,
            "n_convLayer": 4,
            "n_convChannel": [64, 32, 16, 8],
            "filter_size": [1, 3, 3, 3],
            "stride": [1, 2, 1, 1],
            "n_fcLayer": 2,
            "n_fcChannel": [512, 256]
        }
    },
    "data_loader": {
        "type": "CollectDataLoader",
        "args":{
            "data_dir": ["dataset/medley_subset/m64-medley"],
            "batch_size": 64,
            "shuffle": true,
            "validation_split": 0.1,
            "num_workers": 4,
            "subset": "train"
        }
    },
    "optimizer": {
        "type": "Adam",
        "args":{
            "lr": 0.0005,
            "weight_decay": 1e-5,
            "amsgrad": true
        }
    },
    "loss": "vae_loss",
    "metrics": [
        "my_metric", "my_metric2"
    ],
    "lr_scheduler": {
        "type": "StepLR",
        "args": {
            "step_size": 100,
            "gamma": 0.5
        }
    },
    "trainer": {
        "type": "SpecVaeTrainer",
        "epochs": 500,

        "save_dir": "saved/",
        "save_period": 20,
        "verbosity": 2,
        
        "monitor": "min val_loss",
        "early_stop": 30,
        
        "tensorboardX": true
    }
}
